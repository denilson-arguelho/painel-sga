# Painel SGA - Environment Configuration

# Application
NODE_ENV=production
VUE_APP_TITLE=Painel SGA

# API Configuration
VUE_APP_API_URL=http://localhost:8080/api
VUE_APP_API_TIMEOUT=30000

# UI Configuration
VUE_APP_LOCALE=pt_BR
VUE_APP_THEME=novosga.modern

# Features
VUE_APP_SPEECH_ENABLED=true
VUE_APP_ALERT_ENABLED=true

# Docker/Portainer
COMPOSE_PROJECT_NAME=painel-sga
